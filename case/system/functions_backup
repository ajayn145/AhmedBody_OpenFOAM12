FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      functions;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#includeFunc patchAverage(patch=inlet, fields=(p U))

forces
{
    type forces;
    libs ("libforces.so");

    patches (body);

    rhoInf 1.225;
    CofR (0 0 0);

    writeControl timeStep;
    writeInterval 1;
}

