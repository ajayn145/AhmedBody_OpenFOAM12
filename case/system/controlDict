FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     foamRun;

solver          incompressibleFluid;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         5;

deltaT          1e-04;

writeControl    timeStep;

writeInterval   100;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable yes;

adjustTimeStep  yes;

maxCo           1;

maxDeltaT       0.01;

functions
{
    forces
    {
        type            forces;
        libs            ("libforces.so");

        patches         (body);

        rho             rhoInf;

        rhoInf          1.225;
        
        CofR            (0 0 0);

        writeControl    timeStep;
        writeInterval   1;
	log             yes;
    }
}

